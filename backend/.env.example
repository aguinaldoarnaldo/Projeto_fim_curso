# .env.example

# IMPORTANTE: Em desenvolvimento local, mantenha DEBUG=True.
# Se DEBUG=False, o Django tentará forçar conexões HTTPS (SSL), 
# o que causará erros ao rodar o projeto localmente via 'runserver'.
DEBUG=True

SECRET_KEY=mude-me-para-algo-aleatorio  # Use qualquer texto longo ou gere um com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
ALLOWED_HOSTS=localhost,127.0.0.1

# Banco de Dados
DB_NAME=gestao_escolar
DB_USER=postgres
DB_PASSWORD=sua-senha-aqui
DB_HOST=localhost
DB_PORT=5432

# CORS
ALLOWED_ORIGINS=http://localhost:5173
